NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Local development uses the authenticated Codex CLI automatically.
# Set explicitly to force it when running outside Vercel.
BETWEEN_AI_MODE=codex
BETWEEN_CODEX_MODEL=gpt-5.5
# Optional cold-start ceiling for local Codex requests (45–120 seconds).
BETWEEN_CODEX_TIMEOUT_MS=90000
