{
  "name": "between-care-pitch-video",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "voiceover": "node --experimental-strip-types generate-voiceover.ts",
    "typecheck": "tsc --noEmit",
    "still": "remotion still src/index.ts BetweenCarePitch out/between-care-pitch-preview.png --frame=1515",
    "render": "remotion render src/index.ts BetweenCarePitch out/between-care-pitch-submission.mp4 --codec=h264 --crf=18 --pixel-format=yuv420p --muted --concurrency=1"
  },
  "dependencies": {
    "@remotion/cli": "latest",
    "@remotion/media": "^4.0.491",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "latest"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
