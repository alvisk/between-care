{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "summary": { "type": "string" },
    "planDrift": { "type": "string", "enum": ["low", "moderate", "high"] },
    "evidence": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": { "type": "string" }
    },
    "approvedAction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "rationale": { "type": "string" },
        "followUpMinutes": { "type": "integer", "minimum": 5, "maximum": 1440 }
      },
      "required": ["title", "rationale", "followUpMinutes"]
    },
    "escalate": { "type": "boolean" },
    "handoff": { "type": "string" },
    "safety": { "type": "string" }
  },
  "required": [
    "summary",
    "planDrift",
    "evidence",
    "approvedAction",
    "escalate",
    "handoff",
    "safety"
  ]
}
